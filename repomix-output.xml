  inset: 0;
  background:
    radial-gradient(ellipse at center, rgba(193, 68, 14, 0.12) 0%, transparent 65%),
    radial-gradient(ellipse at 80% 80%, rgba(212, 150, 58, 0.07) 0%, transparent 50%);
  pointer-events: none;
}

.splash-deco-line {
  position: absolute;
  left: 8%; width: 84%; height: 1px;
  background: linear-gradient(90deg, transparent, #d4963a, transparent);
  opacity: 0.2;
}
.splash-deco-line.top    { top: 40px; }
.splash-deco-line.bottom { bottom: 40px; }

.splash-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14px;
  animation: splashEntrada 0.8s ease forwards;
  will-change: transform, opacity; /* Fuerza aceleración por hardware */
}

@keyframes splashEntrada {
  from { opacity: 0; transform: translateY(20px); }
  to   { opacity: 1; transform: translateY(0); }
}

/* Anillo spinner */
.splash-logo-ring {
  position: relative;
  width: 110px;
  height: 110px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8px;
}

.splash-spinner {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  animation: girarSpinner 1.6s linear infinite;
  will-change: transform;
}

.splash-spinner circle {
  fill: none;
  stroke: #d4963a;
  stroke-width: 3;
  stroke-linecap: round;
  stroke-dasharray: 120 165;
}

@keyframes girarSpinner {
  from { transform: rotate(0deg); }
  to   { transform: rotate(360deg); }
}

/* Icono cubiertos — pulso suave aislado */
.splash-cutlery {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #c1440e;
  border-radius: 50%;
  width: 72px;
  height: 72px;
  box-shadow: 0 0 25px rgba(193, 68, 14, 0.45);
  animation: cutleryPulse 1.8s ease-in-out infinite;
  will-change: transform, box-shadow;
}

@keyframes cutleryPulse {
  /* translateZ(0) mantiene el elemento aislado en su propia capa de renderizado */
  0%, 100% { box-shadow: 0 0 20px rgba(193, 68, 14, 0.4); transform: scale(1) translateZ(0); }
  50%       { box-shadow: 0 0 35px rgba(193, 68, 14, 0.7); transform: scale(1.05) translateZ(0); }
}

/* Textos */
.splash-title {
  font-family: 'Playfair Display', Georgia, serif;
  font-size: 3rem;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: 6px;
  margin: 0;
  text-shadow: 0 4px 20px rgba(0,0,0,0.6);
}

.splash-subtitle {
  font-family: 'Playfair Display', Georgia, serif;
  font-size: 1rem;
  font-style: italic;
  color: #e2d3c5;
  margin: 0;
  letter-spacing: 1px;
}

.splash-ornament {
  display: flex;
  align-items: center;
  gap: 12px;
  opacity: 0.6;
}
.splash-ornament .orn-line    { width: 60px; height: 1px; background: #d4963a; }
.splash-ornament .orn-diamond { width: 6px; height: 6px; transform: rotate(45deg); background: #d4963a; }

.splash-tagline {
  font-family: 'Lato', sans-serif;
  font-size: 0.75rem;
  letter-spacing: 3px;
  color: #d4963a;
  text-transform: uppercase;
  margin: 0;
  animation: parpadeo 1.4s ease-in-out infinite;
}

@keyframes parpadeo {
  0%, 100% { opacity: 0.4; }
  50%       { opacity: 1; }
}
</file>

