/* ==========================================================================
   PANEL CONTENEDOR DE LAS MESAS (GRID MAPA OPERATIVO)
   ========================================================================== */
.mesas-operativas-panel {
  display: grid;
  /* Mantiene un tamaño mínimo cómodo para que la cuadrícula sea armónica */
  grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
  gap: 20px;
  width: 100%;
  box-sizing: border-box;
}

/* ==========================================================================
   ESTRUCTURA DE LA TARJETA BASE
   ========================================================================== */
.mesa-card {
  background: #ffffff;
  border: none;
  padding: 0;
  cursor: pointer;
  border-radius: 12px;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  font-family: var(--font-sans, system-ui, -apple-system, sans-serif);
  transition: transform 0.2s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.2s ease, border-color 0.2s ease;
  border: 1.5px solid transparent;
  box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03);
  width: 100%;
}

/* Efectos premium interactivos al pasar el mouse y hacer clic */
.mesa-card:hover { 
  transform: translateY(-4px); 
  box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.08), 0 4px 6px -4px rgba(0, 0, 0, 0.08);
}

.mesa-card:active { 
  transform: translateY(-1px); 
}

/* ==========================================================================
   IMAGEN DE LA MESA Y EFECTOS VISUALES
   ========================================================================== */
.mesa-card__img-wrap {
  position: relative;
  width: 100%;
  height: 130px; /* Altura ideal balanceada para vistas de mesas */
  overflow: hidden;
  background-color: #f1f5f9;
}

.mesa-card__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.3s ease;
}

.mesa-card:hover .mesa-card__img {
  transform: scale(1.06); /* Sutil zoom de la imagen */
}

.mesa-card__overlay {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.12); /* Capa oscura inicial para integrar la foto */
  pointer-events: none;
  transition: background 0.2s ease;
}

.mesa-card:hover .mesa-card__overlay {
  background: rgba(0, 0, 0, 0.04); /* Se aclara en hover para resaltar la foto */
}

/* ==========================================================================
   FOOTER REESTRUCTURADO (DOS FILAS - PREVIENE RECORTES)
   ========================================================================== */
.mesa-card__footer {
  background: #ffffff;
  border-top: 1px solid rgba(0, 0, 0, 0.06);
  padding: 12px;
  display: flex;
  flex-direction: column; /* Apila las filas verticalmente */
  gap: 8px; /* Separación balanceada entre la info y el badge */
  width: 100%;
  box-sizing: border-box;
}

/* Fila 1: Distribución horizontal del número y los asientos */
.mesa-card__row-superior {
  display: flex;
  align-items: center;
  justify-content: space-between; /* Empuja el número a la izquierda y capacidad a la derecha */
