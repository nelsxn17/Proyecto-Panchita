}

/* ── ESTADOS ACTIVOS (CUANDO BAJAS EL SCROLL Y ENTRA EN PANTALLA) ── */
.seccion-introduccion-animada.activo .parallax-reveal-left {
  opacity: 1;
  transform: translate3d(0, 0, 0);
}

.seccion-introduccion-animada.activo .parallax-reveal-right {
  opacity: 1;
