.hero-parallax-wrapper {
  position: relative;
  width: 100%;
  /* Asegura un espacio perfecto considerando el alto combinado del topbar y navbar */
  height: calc(100vh - 150px); 
  min-height: 550px;
  /* Bloquea barras de desborde internas */
  overflow: hidden !important; 
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #120904;
}

.parallax-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 120%; /* Le damos un 20% extra para que el efecto translate3d tenga margen abajo y no muestre fondo vacío */
  z-index: 1;
  will-change: transform;
}

.carrusel-slide-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;   
  height: 100%;  
  background-position: center center;
  background-repeat: no-repeat;
  background-size: cover;   
  opacity: 0; 
  /* Transición de opacidad suavizada */
  transition: opacity 1.8s ease-in-out; 
  /* CORREGIDO: Mismo z-index base para que el fundido sea limpio y sin saltos entre ciclos */
  z-index: 2; 
}

.carrusel-slide-bg.active {
  opacity: 1;
}

.vignette {
  position: absolute;
