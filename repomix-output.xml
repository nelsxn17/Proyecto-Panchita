}

.mesa-card__numero {
  font-size: 0.95rem;
  font-weight: 700;
  color: #0f172a;
}

.mesa-card__capacidad {
  font-size: 0.75rem;
  color: #64748b;
  font-weight: 500;
}

/* Fila 2: Bloque del Badge completo */
